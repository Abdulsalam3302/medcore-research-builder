# LLM Provider Configuration
# Choose: "minimax" (default), "anthropic", or "openai".
LLM_PROVIDER=minimax

# --- MiniMax (default) ---
# Works with the native MiniMax API or any OpenAI-compatible gateway
# that fronts MiniMax models. We POST to {base_url}/chat/completions
# using OpenAI chat-completions shape.
MINIMAX_API_KEY=
# Default base URL (MiniMax international, OpenAI-compatible).
# Override for a proxy/gateway such as CometAPI, OpenRouter, etc.
# Examples:
#   https://api.minimaxi.chat/v1       (MiniMax international)
#   https://api.minimax.chat/v1        (MiniMax China)
#   https://api.cometapi.com/v1        (CometAPI gateway)
MINIMAX_BASE_URL=https://api.minimaxi.chat/v1
MINIMAX_MODEL=MiniMax-Text-01

# --- Anthropic (optional) ---
# https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# --- OpenAI (optional fallback) ---
# https://platform.openai.com/
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- NCBI / PubMed E-utilities ---
# Optional but recommended for higher rate limits.
# https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_API_KEY=
NCBI_TOOL=MedCoreResearchBuilder
NCBI_EMAIL=

# --- Crossref polite pool ---
# https://www.crossref.org/documentation/retrieve-metadata/rest-api/#etiquette
CROSSREF_MAILTO=

# --- OpenAlex polite pool ---
# https://docs.openalex.org/how-to-use-the-api/rate-limits-and-authentication
OPENALEX_MAILTO=
# Optional premium API key for higher rate limits.
OPENALEX_API_KEY=

# --- Semantic Scholar (S2) ---
# https://api.semanticscholar.org/api-docs/
# Free tier works without a key; key unlocks higher rate limits.
SEMANTIC_SCHOLAR_API_KEY=

# --- Elicit (AI research assistant) ---
# https://elicit.com/ — paid API
ELICIT_API_KEY=

# --- Unpaywall (free OA PDF resolver — email required for polite pool) ---
# https://unpaywall.org/products/api
UNPAYWALL_EMAIL=

# --- Optional web search (only one needed) ---
TAVILY_API_KEY=
SERPAPI_API_KEY=

# Base URL for the app (used for absolute links in exports)
APP_BASE_URL=http://localhost:5117
