# LLM Provider Configuration
# Choose: "minimax" (default), "anthropic", or "openai".
LLM_PROVIDER=minimax

# --- MiniMax (default) ---
# Works with the native MiniMax API or any OpenAI-compatible gateway
# that fronts MiniMax models. We POST to {base_url}/chat/completions
# using OpenAI chat-completions shape.
MINIMAX_API_KEY=
# Default base URL (MiniMax international, OpenAI-compatible).
# Override for a proxy/gateway such as CometAPI, OpenRouter, etc.
# Examples:
#   https://api.minimaxi.chat/v1       (MiniMax international)
#   https://api.minimax.chat/v1        (MiniMax China)
#   https://api.cometapi.com/v1        (CometAPI gateway)
MINIMAX_BASE_URL=https://api.minimaxi.chat/v1
MINIMAX_MODEL=MiniMax-Text-01

# --- Anthropic (optional) ---
# https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# --- OpenAI (optional fallback) ---
# https://platform.openai.com/
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- NCBI / PubMed E-utilities ---
# Optional but recommended for higher rate limits.
# https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_API_KEY=
NCBI_TOOL=MedCoreResearchBuilder
NCBI_EMAIL=

# --- Scholarly identification (recommended) ---
# A single contact email used in the User-Agent for all scholarly API calls
# (NCBI, OpenAlex, EuropePMC, Unpaywall, OpenCitations, ClinicalTrials).
# Improves "polite pool" standing and reduces 403/throttling from datacenter
# IPs. Falls back to the per-provider mailto values below when unset.
SCHOLARLY_MAILTO=
# Outbound timeout for scholarly requests in ms (default 20000).
SCHOLARLY_TIMEOUT_MS=

# --- Crossref polite pool ---
# https://www.crossref.org/documentation/retrieve-metadata/rest-api/#etiquette
CROSSREF_MAILTO=

# --- OpenAlex polite pool ---
# https://docs.openalex.org/how-to-use-the-api/rate-limits-and-authentication
OPENALEX_MAILTO=
# Optional premium API key for higher rate limits.
OPENALEX_API_KEY=

# --- Semantic Scholar (S2) ---
# https://api.semanticscholar.org/api-docs/
# Free tier works without a key; key unlocks higher rate limits.
SEMANTIC_SCHOLAR_API_KEY=

# --- Elicit (AI research assistant) ---
# https://elicit.com/ — paid API
ELICIT_API_KEY=

# --- Unpaywall (free OA PDF resolver — email required for polite pool) ---
# https://unpaywall.org/products/api
UNPAYWALL_EMAIL=

# --- Optional web search (only one needed) ---
TAVILY_API_KEY=
SERPAPI_API_KEY=

# Base URL for the app (used for absolute links in exports)
APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase (dedicated project: medcore-research-builder) ---
# Auth + cloud project sync. Create a SEPARATE project — do not share with other apps.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional: service role for admin scripts only — never expose to client
SUPABASE_SERVICE_ROLE_KEY=

# Admin promotion on login (real email — no .local domains)
OWNER_EMAIL=kubee3302@gmail.com

# Comma-separated origins for CORS if splitting API later
ALLOWED_ORIGINS=http://localhost:3000,https://medcore-research-builder.vercel.app

# --- Durable rate limiting (recommended for serverless / Vercel) ---
# Upstash Redis REST credentials. When set, API rate limits are enforced in
# Redis so they hold across all serverless instances. Without these the app
# falls back to a per-process in-memory limiter (fine for single-node/self-host).
# Create a free database at https://upstash.com → REST API section.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
